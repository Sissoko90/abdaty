{
  "uid": "abdaty-backend",
  "title": "Abdaty Backend — Vue d'ensemble",
  "tags": ["abdaty", "backend", "spring-boot"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(up, job)",
        "current": { "text": "abdaty-backend", "value": "abdaty-backend" },
        "includeAll": false,
        "refresh": 2
      }
    ]
  },
  "panels": [
    { "type": "row", "title": "Vue d'ensemble", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 } },
    {
      "type": "stat", "title": "Statut application", "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "up{job=\"$job\"}", "refId": "A" } ],
      "fieldConfig": { "defaults": { "mappings": [ { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } } ], "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] } } },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat", "title": "Uptime", "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "process_uptime_seconds{job=\"$job\"}", "refId": "A" } ],
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 0 } },
      "options": { "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "gauge", "title": "CPU (process)", "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "process_cpu_usage{job=\"$job\"}", "refId": "A" } ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.85 } ] } } }
    },
    {
      "type": "gauge", "title": "Heap utilisée", "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "sum(jvm_memory_used_bytes{job=\"$job\",area=\"heap\"}) / sum(jvm_memory_max_bytes{job=\"$job\",area=\"heap\"})", "refId": "A" } ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.75 }, { "color": "red", "value": 0.9 } ] } } }
    },
    {
      "type": "stat", "title": "Threads", "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "jvm_threads_live_threads{job=\"$job\"}", "refId": "A" } ],
      "options": { "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat", "title": "Requêtes / s", "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "sum(rate(http_server_requests_seconds_count{job=\"$job\"}[1m]))", "refId": "A" } ],
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 1 } },
      "options": { "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },

    { "type": "row", "title": "HTTP (RED : Rate / Errors / Duration)", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 } },
    {
      "type": "timeseries", "title": "Débit par statut", "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "sum by (status) (rate(http_server_requests_seconds_count{job=\"$job\"}[1m]))", "legendFormat": "{{status}}", "refId": "A" } ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal" } } } }
    },
    {
      "type": "timeseries", "title": "Taux d'erreur 5xx / 4xx", "gridPos": { "h": 8, "w": 8, "x": 8, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(http_server_requests_seconds_count{job=\"$job\",status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_server_requests_seconds_count{job=\"$job\"}[5m])), 0.001)", "legendFormat": "5xx", "refId": "A" },
        { "expr": "sum(rate(http_server_requests_seconds_count{job=\"$job\",status=~\"4..\"}[5m])) / clamp_min(sum(rate(http_server_requests_seconds_count{job=\"$job\"}[5m])), 0.001)", "legendFormat": "4xx", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0 } }
    },
    {
      "type": "timeseries", "title": "Latence (p50 / p95 / p99)", "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_requests_seconds_bucket{job=\"$job\"}[5m])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{job=\"$job\"}[5m])))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_requests_seconds_bucket{job=\"$job\"}[5m])))", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "table", "title": "Top endpoints (req/s, 5m)", "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "topk(10, sum by (uri, method) (rate(http_server_requests_seconds_count{job=\"$job\"}[5m])))", "format": "table", "instant": true, "refId": "A" } ]
    },
    {
      "type": "timeseries", "title": "Latence moyenne par endpoint (top)", "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "topk(8, sum by (uri) (rate(http_server_requests_seconds_sum{job=\"$job\"}[5m])) / clamp_min(sum by (uri) (rate(http_server_requests_seconds_count{job=\"$job\"}[5m])), 0.001))", "legendFormat": "{{uri}}", "refId": "A" } ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },

    { "type": "row", "title": "JVM / Ressources", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 } },
    {
      "type": "timeseries", "title": "Mémoire JVM (heap vs non-heap)", "gridPos": { "h": 8, "w": 8, "x": 0, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(jvm_memory_used_bytes{job=\"$job\",area=\"heap\"})", "legendFormat": "heap utilisée", "refId": "A" },
        { "expr": "sum(jvm_memory_max_bytes{job=\"$job\",area=\"heap\"})", "legendFormat": "heap max", "refId": "B" },
        { "expr": "sum(jvm_memory_used_bytes{job=\"$job\",area=\"nonheap\"})", "legendFormat": "non-heap utilisée", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "type": "timeseries", "title": "CPU process vs système", "gridPos": { "h": 8, "w": 8, "x": 8, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "process_cpu_usage{job=\"$job\"}", "legendFormat": "process", "refId": "A" },
        { "expr": "system_cpu_usage{job=\"$job\"}", "legendFormat": "système", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } }
    },
    {
      "type": "timeseries", "title": "GC (pause/s) & Threads", "gridPos": { "h": 8, "w": 8, "x": 16, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(jvm_gc_pause_seconds_sum{job=\"$job\"}[1m]))", "legendFormat": "GC pause/s", "refId": "A" },
        { "expr": "jvm_threads_live_threads{job=\"$job\"}", "legendFormat": "threads", "refId": "B" }
      ]
    },

    { "type": "row", "title": "Logs (Loki)", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 } },
    {
      "type": "logs", "title": "Logs applicatifs (erreurs en surbrillance)", "gridPos": { "h": 10, "w": 24, "x": 0, "y": 32 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [ { "expr": "{job=\"abdaty-backend\"}", "refId": "A" } ],
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending", "enableLogDetails": true }
    }
  ]
}
