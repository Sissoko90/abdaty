# Configuration de l'environnement
ENVIRONMENT=development

# Configuration de l'application
APP_NAME=Abdaty Backend
APP_VERSION=1.0.0
SERVER_PORT=8080

# Configuration de Vault (production)
VAULT_ENABLED=false
VAULT_URI=http://localhost:8200
VAULT_TOKEN=

# Configuration de la base de données PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=abdatydb
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_POOL_SIZE=10
DB_MAX_LIFETIME=1800000
DB_IDLE_TIMEOUT=600000

# Configuration de Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0
REDIS_TIMEOUT=5000
REDIS_POOL_SIZE=10

# Configuration de Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CONSUMER_GROUP=abdaty-group
KAFKA_TOPIC_USERS=users-topic

# Configuration du mail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-password
MAIL_FROM=noreply@abdaty.com

# Configuration de Zipkin
ZIPKIN_URL=http://localhost:9411
ZIPKIN_ENABLED=true

# Configuration de la sécurité JWT
JWT_SECRET=mySecretKeyForJWT1234567890123456789012345678901234567890
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# Configuration de Resilience4j Circuit Breaker
CIRCUIT_BREAKER_FAILURE_RATE_THRESHOLD=50
CIRCUIT_BREAKER_WAIT_DURATION_IN_OPEN_STATE=60000
CIRCUIT_BREAKER_PERMITTED_NUMBER_OF_CALLS_IN_HALF_OPEN_STATE=3
CIRCUIT_BREAKER_SLIDING_WINDOW_SIZE=10
CIRCUIT_BREAKER_MINIMUM_NUMBER_OF_CALLS=5

# Configuration de Resilience4j Retry
RETRY_MAX_ATTEMPTS=3
RETRY_WAIT_DURATION=1000
RETRY_INTERVAL_FUNCTION=1000

# Configuration du cache
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# Configuration de la pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Configuration Netty
NETTY_MAX_CONNECTIONS=1000
NETTY_PENDING_ACQUIRE_TIMEOUT=60000
NETTY_PENDING_ACQUIRE_MAX_COUNT=2000
NETTY_MAX_IDLE_TIME=30000
NETTY_MAX_LIFE_TIME=300000
NETTY_RECEIVE_BUFFER_SIZE=262144
NETTY_SEND_BUFFER_SIZE=262144
NETTY_KEEP_ALIVE=60

# Configuration de l'observabilité
METRICS_ENABLED=true
TRACING_ENABLED=true
GRAFANA_ENABLED=true
PROMETHEUS_ENABLED=true

# Configuration de Swagger
SWAGGER_ENABLED=true
SWAGGER_PATH=/swagger-ui.html

# Configuration de la validation
VALIDATION_ENABLED=true
VERIFICATION_CODE_EXPIRATION_MINUTES=15

# Configuration de l'API
API_PREFIX=/api
API_VERSION=v1

# Configuration de la sécurité
CORS_ENABLED=true
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOWED_HEADERS=*
CORS_ALLOW_CREDENTIALS=true

# Configuration des timeouts
REQUEST_TIMEOUT=30000
READ_TIMEOUT=30000
WRITE_TIMEOUT=30000
