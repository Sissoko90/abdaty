  "legal": {
    "termsOfService": {
      "title": "Conditions Générales d'Utilisation",
      "lastUpdated": "Dernière mise à jour : 7 mai 2026",
      "backToHome": "← Retour à l'accueil",
      "acceptance": {
        "title": "1. Acceptation des Conditions",
        "content": "En accédant au site web d'Abdaty Technologie et en utilisant nos services, vous acceptez d'être lié par les présentes Conditions Générales d'Utilisation (« CGU »). Si vous n'acceptez pas ces conditions dans leur intégralité, vous ne devez pas accéder à ce site web ni utiliser nos services. L'accès à ce site web et l'utilisation de nos services sont soumis aux présentes CGU ainsi qu'à notre Politique de Confidentialité."
      },
      "services": {
        "title": "2. Nos Services",
        "content": "Abdaty Technologie propose une gamme complète de services technologiques incluant, sans s'y limiter, le développement d'applications web et mobile, le développement logiciel desktop, le design UI/UX, l'infrastructure réseau, la cybersécurité, et l'analyse de données et intelligence artificielle. Nous nous réservons le droit de modifier, suspendre ou interrompre tout service à tout moment, sans préavis, pour quelque raison que ce soit, y compris mais sans s'y limiter, pour des raisons de maintenance, de mise à jour ou d'amélioration technique."
      },
      "userAccount": {
        "title": "3. Compte Utilisateur",
        "content": "Pour accéder à certains de nos services, vous devez créer un compte utilisateur. Vous déclarez et garantissez que toutes les informations que vous fournissez lors de l'inscription sont exactes, complètes et à jour. Vous êtes responsable de la confidentialité de votre mot de passe et de toutes les activités qui surviennent sous votre compte. Vous acceptez de nous notifier immédiatement toute utilisation non autorisée de votre compte.",
        "points": {
          "accuracy": "Maintenir l'exactitude et l'exhaustivité de vos informations personnelles",
          "security": "Sécuriser votre mot de passe et votre compte contre tout accès non autorisé",
          "responsibility": "Assumer l'entière responsabilité de toutes les activités effectuées sous votre compte"
        }
      },
      "payment": {
        "title": "4. Modalités de Paiement",
        "content": "Les paiements pour nos services sont effectués conformément aux tarifs affichés sur notre site web au moment de la commande. Nous acceptons divers modes de paiement incluant cartes bancaires, virements bancaires et autres méthodes de paiement électronique sécurisées. Tous les paiements sont non remboursables sauf disposition contraire expresse dans nos Conditions de Vente spécifiques ou en cas de non-exécution de nos obligations contractuelles."
      },
      "cancellation": {
        "title": "5. Annulation et Remboursement",
        "content": "Vous pouvez annuler votre abonnement à tout moment en vous connectant à votre compte et en suivant la procédure d'annulation. L'annulation prendra effet à la fin de la période de facturation en cours. Aucun remboursement partiel ou proportionnel ne sera accordé pour la période en cours. En cas de résiliation anticipée d'un contrat de service, les modalités de remboursement seront définies dans le contrat spécifique."
      },
      "limitation": {
        "title": "6. Limitation de Responsabilité",
        "content": "Dans la mesure maximale permise par la loi applicable, Abdaty Technologie ne sera pas responsable des dommages directs, indirects, fortuits, consécutifs ou punitifs résultant de l'utilisation ou de l'impossibilité d'utiliser nos services. Cette limitation s'applique aux dommages pour perte de profits, perte de données, interruption d'activité, ou toute autre perte pécuniaire, même si Abdaty Technologie a été informée de la possibilité de tels dommages."
      },
      "intellectual": {
        "title": "7. Propriété Intellectuelle",
        "content": "Tout le contenu, les marques, les logos, les graphismes, les logiciels, les bases de données et les droits d'auteur sur ce site web sont la propriété exclusive d'Abdaty Technologie ou de ses concédants et sont protégés par les lois nationales et internationales sur la propriété intellectuelle. Vous ne pouvez pas reproduire, distribuer, modifier, adapter, publier, transmettre, créer des œuvres dérivées ou utiliser ce contenu, en tout ou en partie, sans notre autorisation écrite préalable."
      },
      "privacy": {
        "title": "8. Confidentialité des Données",
        "content": "Votre vie privée est d'une importance capitale pour nous. Nous nous engageons à protéger vos données personnelles conformément à notre",
        "link": "Politique de Confidentialité"
      },
      "modifications": {
        "title": "9. Modifications des Conditions",
        "content": "Nous nous réservons le droit de modifier ces Conditions Générales d'Utilisation à tout moment et à notre discrétion. Toutes les modifications prendront effet immédiatement dès leur publication sur ce site web. Votre utilisation continue de nos services après la publication des modifications constitue votre acceptation des nouvelles conditions. Il est de votre responsabilité de consulter régulièrement les présentes CGU pour rester informé des modifications."
      },
      "contact": {
        "title": "10. Contact et Support",
        "content": "Pour toute question concernant ces Conditions Générales d'Utilisation, ou pour signaler une violation potentielle, veuillez nous contacter via notre",
        "link": "page de contact"
      }
    },
    "privacyPolicy": {
      "title": "Politique de Confidentialité",
      "lastUpdated": "Dernière mise à jour : 7 mai 2026",
      "backToHome": "← Retour à l'accueil",
      "introduction": {
        "title": "Introduction",
        "content": "Abdaty Technologie s'engage fermement à protéger la vie privée et la confidentialité des données de ses utilisateurs. La présente Politique de Confidentialité a pour but de vous informer de manière transparente sur la nature, les finalités et les modalités de collecte, de traitement et de protection de vos données personnelles."
      },
      "information": {
        "title": "1. Données Collectées",
        "content": "Nous collectons les catégories suivantes de données personnelles lorsque vous utilisez nos services :",
        "points": {
          "personal": "Données d'identification : nom, prénom, adresse email, numéro de téléphone",
          "contact": "Coordonnées professionnelles : entreprise, fonction, adresse professionnelle",
          "usage": "Données d'utilisation : historique de navigation, préférences, interactions avec nos services",
          "payment": "Données de paiement : informations bancaires sécurisées (traitées conformément aux normes PCI-DSS)"
        }
      },
      "collection": {
        "title": "2. Modalités de Collecte",
        "content": "Les données sont collectées directement auprès de vous lorsque vous créez un compte, souscrivez à nos services, communiquez avec notre équipe client, ou participez à nos programmes promotionnels. Nous pouvons également collecter automatiquement certaines données techniques lors de votre utilisation de notre site web et de nos applications."
      },
      "usage": {
        "title": "3. Utilisation des Données",
        "content": "Vos données personnelles sont utilisées exclusivement pour les finalités suivantes :",
        "points": {
          "service": "Fourniture, personnalisation et amélioration de nos services technologiques",
          "communication": "Communication avec vous concernant votre compte, vos commandes et nos offres",
          "security": "Sécurisation de votre compte et prévention des activités frauduleuses",
          "analytics": "Analyse des tendances d'utilisation pour optimiser nos services et développer de nouvelles fonctionnalités"
        }
      },
      "sharing": {
        "title": "4. Partage des Données",
        "content": "Abdaty Technologie ne vend pas, ne loue pas et ne partage pas vos données personnelles avec des tiers, sauf dans les cas suivants : (i) avec votre consentement explicite, (ii) pour se conformer aux obligations légales ou réglementaires, (iii) pour protéger nos droits ou notre propriété, ou (iv) avec nos sous-traitants dûment autorisés dans le cadre strict de la prestation de services."
      },
      "security": {
        "title": "5. Sécurité des Données",
        "content": "Nous mettons en œuvre des mesures de sécurité techniques et organisationnelles de pointe conformément aux meilleures pratiques de l'industrie pour protéger vos données contre tout accès non autorisé, toute altération, toute divulgation ou toute destruction. Ces mesures incluent le cryptage des données, l'authentification à deux facteurs, et des audits de sécurité réguliers."
      },
      "cookies": {
        "title": "6. Cookies et Technologies Similaires",
        "content": "Nous utilisons des cookies et autres technologies similaires pour améliorer votre expérience utilisateur, analyser l'utilisation de nos services et personnaliser le contenu. Vous pouvez configurer votre navigateur pour refuser les cookies, bien que cela puisse affecter certaines fonctionnalités de notre site web."
      },
      "rights": {
        "title": "7. Vos Droits",
        "content": "Conformément au Règlement Général sur la Protection des Données (RGPD) et aux législations nationales applicables, vous disposez des droits suivants sur vos données personnelles :",
        "points": {
          "access": "Droit d'accès : obtenir confirmation du traitement et une copie de vos données",
          "correction": "Droit de rectification : corriger les données inexactes ou incomplètes",
          "deletion": "Droit à l'effacement : demander la suppression de vos données (droit à l'oubli)",
          "objection": "Droit d'opposition : vous opposer au traitement de vos données pour des motifs légitimes"
        }
      },
      "retention": {
        "title": "8. Conservation des Données",
        "content": "Nous conservons vos données personnelles uniquement pendant la durée nécessaire à la réalisation des finalités pour lesquelles elles ont été collectées, conformément aux exigences légales et réglementaires applicables. À l'expiration de cette durée, les données sont soit supprimées, soit anonymisées."
      },
      "gdpr": {
        "title": "9. Conformité RGPD",
        "content": "Abdaty Technologie est pleinement conforme au Règlement (UE) 2016/679 relatif à la protection des personnes physiques à l'égard du traitement des données à caractère personnel (RGPD). Nous avons désigné un Délégué à la Protection des Données (DPO) et maintenu des registres de traitement conformes aux exigences réglementaires."
      },
      "contact": {
        "title": "10. Contact et Exercice des Droits",
        "content": "Pour toute question relative à cette Politique de Confidentialité, ou pour exercer vos droits sur vos données personnelles, veuillez nous contacter via notre",
        "link": "page de contact"
      }
    }
  },
